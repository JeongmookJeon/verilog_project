#include "SPI.h"

// SPI 초기화
void SPI_Init(SPI_Typedef_t *SPIx, uint8_t clk_div, int cpol, int cpha) {
    uint32_t cr_val = clk_div; // 하위 8비트에 clk_div 설정

    if (cpol) cr_val |= (1 << SPI_CR_CPOL_BIT);
    if (cpha) cr_val |= (1 << SPI_CR_CPHA_BIT);

    // start 비트는 0인 상태로 CR 레지스터에 적용
    SPIx->CR = cr_val;
}

// SPI 8비트 데이터 전송
void SPI_Send(SPI_Typedef_t *SPIx, uint8_t data) {
    // 1. 송신할 데이터를 TX_DATA(slv_reg1)에 기록
    SPIx->TX_DATA = data;

    // 2. 통신 시작 (CR 레지스터의 START 비트를 1로 세팅)
    SPIx->CR |= (1 << SPI_CR_START_BIT);

    // 3. 통신 완료 대기 (SR_RX 레지스터의 DONE 비트 확인)
    while ((SPIx->SR_RX & (1 << SPI_SR_DONE_BIT)) == 0) {
        // Polling 대기
    }

    // 4. 다음 전송을 위해 START 비트 강하
    SPIx->CR &= ~(1 << SPI_CR_START_BIT);
}
