#include "ap_main.h"
#include "../HAL/GPIO/GPIO.h"
#include "../HAL/SPI/SPI.h"

void ap_init() {
    // 1. 스위치 8개 입력 핀 초기화 (GPIOB)
    GPIO_SetMode(GPIOB, 0xFF, INPUT);

    // 2. SPI 마스터 초기화 (속도를 매우 낮춰 노이즈 방지: clk_div = 200)
    // CPOL=0, CPHA=0 모드
    SPI_Init(SPI0, 200, 0, 0);
}

void ap_excute() {
    while (1) {
        // 1. 현재 딥스위치 상태(0~255) 읽어오기
        uint8_t sw_data = GPIO_ReadPort(GPIOB) & 0xFF;

        // 2. 읽어온 스위치 값을 슬레이브로 냅다 전송!
        SPI_Send(SPI0, sw_data);

        // 3. 무식한 소프트웨어 딜레이 (타이머 인터럽트 충돌 방지)
        // 약 수십 ms 동안 대기하여 너무 빠르게 전송되는 것을 방지합니다.
        for (volatile int i = 0; i < 500000; i++) {
            // 아무것도 안 하면서 CPU 시간만 소모
        }
    }
}
