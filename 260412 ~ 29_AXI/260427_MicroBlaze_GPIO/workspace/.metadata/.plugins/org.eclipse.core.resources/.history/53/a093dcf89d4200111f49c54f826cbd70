#define GPIOB_ODR  (*(uint32_t*) (XPAR_GPIO8_1_S00_AXI_BASEADDR + 0x08))


#define GPIOA ((GPIO_Typedef_t *)(XPAR_GPIO8_0_S00_AXI_BASEADDR))
#define GPIOB ((GPIO_Typedef_t *)(XPAR_GPIO8_1_S00_AXI_BASEADDR))

#define GPIO_PIN_0 0x01 // 0b00000001
#define GPIO_PIN_1 0x02 // 0b00000010
#define GPIO_PIN_2 0x04 // 0b00000100
#define GPIO_PIN_3 0x08 // 0b00001000
#define GPIO_PIN_4 0x10 // 0b00010000
#define GPIO_PIN_5 0x20 // 0b00100000
#define GPIO_PIN_6 0x40 // 0b01000000
#define GPIO_PIN_7 0x80 // 0b10000000

#define INPUT  0
#define OUTPUT 1//CRё»°н!! ұЧіЙ output

#define RESET 0
#define SET   1

//' GPIO_Typedef_t *' ЗьЕВАЗ БЦјТёҰ №Ю°ЪҙЩ
//ҫЖ·Ў  voidҙВ HAL(GPIO) layerёҰ ёёөйҫъҙЩ°н әёёй өК!!
void GPIO_SetMode(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin, int GPIO_Dir)
{
	if(GPIO_Dir ==OUTPUT){
		GPIOx -> CR |= GPIO_Pin;
	}
	else {
		GPIOx -> CR &= ~(GPIO_Pin);
	}
}
void GPIO_WritePin(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin, int level)
{
	if(level == SET){
		GPIOx -> ODR |= GPIO_Pin;
	}
	else{
		GPIOx -> ODR &= ~GPIO_Pin;
	}
}
void GPIO_ReadPin(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin)
{
	return (GPIOx -> IDR & GPIO_Pin) ? 1 : 0; // °эИЈ ҫИАМ 0АМёй °ЕБю іӘёУБш Вь!!!
}

void GPIO_WritePort(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin, int data)
{
	GPIOx->ODR = data;
}
void GPIO_ReadPort(GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin)
{
	return GPIOx ->IDR;
}

