void FND_SetNum(uint16_t num) {
	fndNumData = num;
}

void FND_DispAllOn() {
	FND_SetComPort(FND_COM_PORT,
			FND_COM_DIG_1 | FND_COM_DIG_2 | FND_COM_DIG_3 | FND_COM_DIG_4, OFF);
}

void FND_DispAllOff() {
	FND_SetComPort(FND_COM_PORT,
			FND_COM_DIG_1 | FND_COM_DIG_2 | FND_COM_DIG_3 | FND_COM_DIG_4, OFF);
}

