#define INTC_DEV_ID XPAR_INTC_0_DEVICE_ID
#define TMR1_DEV_ID XPAR_INTC_1_DEVICE_ID
#define TMR2_DEV_ID XPAR_INTC_2_DEVICE_ID

XIntc IntrController;

void TMR1_ISR(void *CallbackRef)
{

}
void TMR2_ISR(void *CallbackRef)
{

}

int SetupInterruptSystem()
{
	int status;
	//1. 인터럽트 컨트롤러 초기화
	status = XIntc_Initialize(&IntrController, INTC_DEV_ID);
	if(status != XST_SUCCESS){
		return XST_FAILURE;
	}

	//2-1. TMR1_ISR 함수를 Intc와 연결
	status = XIntc_Connect(&IntrController, TMR1_DEV_ID, (XInterruptHandler)TMR1_ISR,(void *)0 );
	if(status !=XST_SUCESS){
		return XST_FAILURE;
	}
	//2-2 TMR2-ISR 함수를 INTC와 연결
	status = XIntc_Connect(&IntrController, TMR2_DEV_ID, (XInterruptHandler)TMR2_ISR,(void *)0 );
		if(status !=XST_SUCESS){
			return XST_FAILURE;
		}
		//3. Interrupt Controller 시작
		status = XIntc_Start(&IntrControll, XIN_REAL_MODE);
		if(status !=XST_SUCESS){
					return XST_FAILURE;
		}
		//4. 각각의  인터럽트 채널 활성화
		XIntc_Enable(&IntrController, TMR1_DEV_ID);
		XIntc_Enable(&IntrController, TMR2_DEV_ID);

		//5. MicroBlaze의 Exception 초기화 및 활성화
		//제일 마지막 한번 실행
		//CPU와 인터럽트컨트롤러 연결시켜주는 부분
		//초기화
		xil_ExceptionInit();
		Xil_ExceptionRegisterHandler(XIL_EXCEPTION_ID_INT,
				(Xil_ExceptionHandler)XIntc_InterruptHandler,
				&IntrController);

		//활성화
		Xil_ExceptionDisable();
}

typedef enum {
    WATCH = 0,
    UPCOUNTER = 1
} Mode_state_t;

Mode_state_t curMode = WATCH; // 기본 화면은 시계(Watch)로 시작
hBtn_t hBtnMode; // 모드 변경을 담당할 버튼 구조체

void ap_init()
{
    // 각 하위 서비스들 초기화
    Watch_Init();
    UpCounter_Init();

    // 모드 변경 버튼 초기화 (PIN_5)
    Button_Init(&hBtnMode, GPIOA, GPIO_PIN_5);
}

//모든  code를 무한 Loop 돌면서 동작하는 방식을 "super loop 방식"이라고 함.
void ap_excute()
{
    while(1)
    {
        // 1. 모드 버튼이 눌렸는지 확인하고 선로(Mode) 바꾸기
        if (Button_GetState(&hBtnMode) == ACT_PUSHED) {

            // 시계 -> 업카운터 -> 시계로 토글(Toggle)
            if (curMode == WATCH) {
                curMode = UPCOUNTER;
            } else {
                curMode = WATCH;
            }

            // 모드가 바뀔 때 이전 모드의 FND 잔상을 지워줍니다.
            FND_DispAllOff();
        }

        // 2. 현재 선로(Mode)에 맞는 서비스만 실행하기
        if (curMode == WATCH) {
            Watch_Execute();
        } else if (curMode == UPCOUNTER) {
            UpCounter_Excute();
        }

        millis_inc(); // 전역변수를 1씩 증가하는 것만 있음.
        delay_ms(1); //1ms 간격으로 찍어줌.
    }
}

