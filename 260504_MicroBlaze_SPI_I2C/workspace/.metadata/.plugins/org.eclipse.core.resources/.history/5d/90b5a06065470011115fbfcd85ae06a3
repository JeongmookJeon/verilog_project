#ifndef SRC_HAL_SPI_SPI_H_
#define SRC_HAL_SPI_SPI_H_

#include <stdint.h>
#include "xparameters.h"

// SPI 하드웨어 레지스터 구조체 맵핑
typedef struct {
    uint32_t CR;       // slv_reg0: Control Register (offset: 0x00)
    uint32_t TX_DATA;  // slv_reg1: Transmit Data (offset: 0x04)
    uint32_t SR_RX;    // slv_reg2: Status & Receive Data (offset: 0x08)
} SPI_Typedef_t;

// AXI Base Address 매크로 (xparameters.h에 정의된 이름에 맞게 수정 필요)
#define SPI_BASEADDR XPAR_SPI_0_S00_AXI_BASEADDR
#define SPI0 ((SPI_Typedef_t *) (SPI_BASEADDR))

// Control Register (CR) 비트 위치
#define SPI_CR_CPOL_BIT   8
#define SPI_CR_CPHA_BIT   9
#define SPI_CR_START_BIT  10

// Status Register (SR_RX) 비트 위치
#define SPI_SR_BUSY_BIT   8
#define SPI_SR_DONE_BIT   9

// 함수 프로토타입 선언
void SPI_Init(SPI_Typedef_t *SPIx, uint8_t clk_div, uint8_t cpol, uint8_t cpha);
uint8_t SPI_TransmitReceive(SPI_Typedef_t *SPIx, uint8_t txData);

#endif /* SRC_HAL_SPI_SPI_H_ */
